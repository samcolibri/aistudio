{
  "name": "aistudio",
  "version": "2.0.0",
  "description": "SimpleNursing AI Studio — Veo3 + Imagen4 + Fish Audio + Remotion + Temporal",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "worker": "tsx src/worker.ts",
    "scheduler": "tsx src/scheduler.ts",
    "start": "bash scripts/start.sh",
    "trigger": "tsx src/cli.ts trigger",
    "list": "tsx src/cli.ts list",
    "approve:content": "tsx src/cli.ts approve-content",
    "approve:creative": "tsx src/cli.ts approve-creative",
    "remotion:studio": "cd remotion && npx remotion studio src/Root.tsx",
    "remotion:render": "cd remotion && node render.mjs",
    "temporal:dev": "docker compose -f temporal/docker-compose.yml up -d",
    "index": "tsx src/indexer/index.ts",
    "index:report": "tsx src/indexer/index.ts --report",
    "index:reindex": "tsx src/indexer/index.ts --reindex",
    "index:search": "tsx src/indexer/index.ts search",
    "index:sync": "tsx src/indexer/airtable-sync.ts",
    "produce": "tsx src/produce-now.ts",
    "produce:pinterest": "tsx src/produce-now.ts --rank 6",
    "produce:tiktok": "tsx src/produce-now.ts --rank 1",
    "produce:dry": "tsx src/produce-now.ts --dry",
    "dashboard": "node_modules/.bin/tsx src/dashboard/server.ts",
    "watcher": "node_modules/.bin/tsx src/watcher.ts",
    "studio": "cd remotion && node node_modules/@remotion/cli/remotion-cli.js studio src/Root.tsx --port 3003",
    "start:all": "concurrently \"npm run dashboard\" \"npm run watcher\" \"npm run studio\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@remotion/bundler": "4.0.450",
    "@remotion/cli": "4.0.450",
    "@remotion/renderer": "4.0.450",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "airtable": "^0.12.2",
    "chalk": "^5.3.0",
    "chromadb": "^1.9.2",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
