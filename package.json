{
  "name": "aistudio",
  "version": "1.0.0",
  "description": "AI content studio for SimpleNursing — Temporal-orchestrated video/image/content generation with Nurse Mike",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:scheduler": "tsx watch src/scheduler.ts",
    "worker": "node --loader ts-node/esm src/worker.ts",
    "scheduler": "node --loader ts-node/esm src/scheduler.ts",
    "start": "scripts/start.sh",
    "trigger": "tsx src/cli.ts trigger",
    "list": "tsx src/cli.ts list",
    "temporal:dev": "docker compose -f temporal/docker-compose.yml up -d"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "airtable": "^0.12.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-fetch": "^3.3.2",
    "ora": "^8.1.0",
    "p-limit": "^6.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
