# ── Google AI (Veo 3 + Imagen 4 Ultra) ────────────────────────────────────────
GOOGLE_AI_KEY=                   # ai.google.com → API keys

# ── Voice Synthesis ────────────────────────────────────────────────────────────
FISH_AUDIO_API_KEY=              # fish.audio — $15/M chars, best Nurse Mike voice
FISH_AUDIO_MIKE_ID=              # Fish Audio reference voice ID for Nurse Mike
ELEVENLABS_API_KEY=              # Fallback if Fish Audio unavailable

# ── Airtable (Chad's Dashboard — nova-gtm same base) ──────────────────────────
CHAD_AIRTABLE_API_KEY=           # Personal access token (same as nova-gtm)
CHAD_BASE_ID=appLFh438nLooz6u7
BRIEFS_TABLE_ID=tbl5P3J8agdY4gNtT

# ── Cloudflare R2 Storage ──────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=simplenursing-aistudio
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://studio.simplenursing.dev

# ── Temporal ───────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=simplenursing-studio

# ── ChromaDB (rejection memory from nova-gtm V8 engine) ───────────────────────
CHROMA_PATH=~/.nova-gtm/chroma   # shared with nova-gtm local DB

# ── Output ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
NOVA_GTM_PATH=~/nova-gtm         # path to nova-gtm repo (for Remotion public assets)
