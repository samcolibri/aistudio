# ─────────────────────────────────────────────────────────────────
#  SimpleNursing AI Studio — Environment Variables
#  cp .env.example .env  →  fill in your keys  →  never commit .env
# ─────────────────────────────────────────────────────────────────

# ── Google AI (Veo3 video + Imagen4 Ultra images) — FREE TIER WORKS ──
# Get at: aistudio.google.com → Get API Key
GOOGLE_AI_KEY=
GOOGLE_API_KEY=

# ── Fish Audio — Sarah female voice narrator ──────────────────────
# Get at: fish.audio/go-api  (needs $2+ credits loaded)
# Sarah voice ID pre-filled — do not change unless swapping voice
FISH_AUDIO_API_KEY=
FISH_AUDIO_MIKE_ID=933563129e564b19a115bedd57b7406a

# ── fal.ai — OmniHuman talking head, Kling Avatar, Flux portraits ─
# Get at: fal.ai/dashboard/keys  (pay-per-use, top up before running)
FAL_KEY=

# ── Airtable — Content Briefs base (Chad/human-approved briefs) ───
# Get at: airtable.com/create/tokens  (Personal Access Token)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appLFh438nLooz6u7

# ── Airtable — AI Studio produced assets library ─────────────────
AIRTABLE_STUDIO_BASE=app4LEuOXBxPArLsr
AIRTABLE_STUDIO_KEY=

# ── OpenAI — DALL-E 3 HD image generation (Agent 2: ImageForge) ──
# Get at: platform.openai.com/api-keys  (~$0.08/image HD)
OPENAI_API_KEY=

# ── Ideogram — Text-in-image / graphic generation (Agent 2) ───────
# Get at: ideogram.ai/api  (~$0.06/image V2)
IDEOGRAM_API_KEY=

# ── Microsoft Graph — OneDrive / SharePoint upload (Agent 3) ──────
# Azure portal → App registrations → Files.ReadWrite.All (app permission)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
# Optional: set to your SharePoint hostname, e.g. colibrigroup.sharepoint.com
# If blank, uses the app's personal OneDrive
MS_SHAREPOINT_SITE=
# Root folder name in OneDrive/SharePoint (default: AI Studio)
MS_DRIVE_FOLDER=AI Studio

# ── Anthropic Claude (script analysis, optional) ──────────────────
ANTHROPIC_API_KEY=

# ── Cloudflare R2 (asset CDN, optional — GitHub releases is default) ─
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── Local asset library (optional) ───────────────────────────────
ASSETS_DIR=/Users/yourname/Downloads/aistudio-assets
